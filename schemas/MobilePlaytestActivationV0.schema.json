{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MobilePlaytestActivationV0",
  "type": "object",
  "required": [
    "schema_version",
    "lane",
    "preview_source_path",
    "playtest_link_artifact",
    "viewport",
    "input_replay",
    "artifacts",
    "status"
  ],
  "properties": {
    "schema_version": {"const": "MobilePlaytestActivationV0"},
    "lane": {"const": "mobile_browser_game_preview"},
    "preview_source_path": {"type": "string"},
    "playtest_link_artifact": {"type": "string"},
    "viewport": {
      "type": "object",
      "required": ["width", "height", "is_mobile", "has_touch"],
      "properties": {
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1},
        "is_mobile": {"type": "boolean"},
        "has_touch": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "input_replay": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 2
    },
    "artifacts": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 3
    },
    "status": {"enum": ["success", "failure"]}
  },
  "additionalProperties": true
}
